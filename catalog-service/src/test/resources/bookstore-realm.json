{
  "realm": "bookstore",
  "enabled": true,

  "clients": [
    {
      "clientId": "catalog-service-api",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "bearerOnly": true
    },
    {
      "clientId": "user-service-admin",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "test-secret",
      "directAccessGrantsEnabled": true,

      "protocolMappers": [
        {
          "name": "audience-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "catalog-service-api",
            "access.token.claim": "true",
            "multivalued": "true"
          }
        }
      ]
    }
  ],

  "roles": {
    "realm": [
      {
        "name": "ADMIN"
      }
    ],
    "client": {
      "user-service-admin": [
        {
          "name": "catalog.read"
        },
        {
          "name": "catalog.write"
        }
      ]
    }
  },

  "users": [
    {
      "username": "usertest",
      "enabled": true,
      "email": "usertest@example.com",
      "emailVerified": true,
      "requiredActions": [],
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ],
      "realmRoles": [
        "ADMIN"
      ],
      "clientRoles": {
        "user-service-admin": [
          "catalog.read"
        ]
      }
    }
  ],
  "requiredActions": [
    {
      "alias": "VERIFY_EMAIL",
      "enabled": false
    },
    {
      "alias": "UPDATE_PASSWORD",
      "enabled": false
    },
    {
      "alias": "CONFIGURE_TOTP",
      "enabled": false
    },
    {
      "alias": "UPDATE_PROFILE",
      "enabled": false
    }
  ]
}